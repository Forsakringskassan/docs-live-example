{
  "name": "@forsakringskassan/docs-live-example",
  "version": "3.0.0",
  "description": "Components used for live examples",
  "keywords": [
    "documentation"
  ],
  "homepage": "https://github.com/Forsakringskassan/docs-live-example",
  "bugs": "https://github.com/Forsakringskassan/docs-live-example/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/docs-live-example.git"
  },
  "license": "MIT",
  "author": "Försäkringskassan",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "sass": "./dist/main.css",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./htmlvalidate": "./htmlvalidate/index.js",
    "./dist/main.css": "./dist/main.css"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "main.css",
    "htmlvalidate",
    "!**/*.spec.js",
    "!**/*.spec.d.ts"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "vue-tsc && node build.mjs",
    "clean": "rimraf dist",
    "eslint": "eslint --cache .",
    "eslint:fix": "eslint --fix .",
    "html-validate": "html-validate --ext vue,html src",
    "lint": "run-s prettier:check eslint html-validate",
    "lint:fix": "run-s prettier:write eslint:fix",
    "prepack": "release-prepack --bundle",
    "postpack": "release-postpack package.json",
    "prepare": "commitlint-config",
    "prepublishOnly": "release-prepublish --bundle",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "prestart": "npm run build",
    "start": "node ./scripts/serve.mjs",
    "pretest": "run-s prettier:check eslint html-validate",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "commitlint": {
    "extends": "@forsakringskassan/commitlint-config/no-jira"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-config"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.[jt]s",
      "!**/*.spec.[jt]s",
      "!**/*.d.ts",
      "!**/index.[jt]s",
      "!**/__fixtures__/**"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "preset": "@forsakringskassan/jest-config/esm"
  },
  "dependencies": {
    "esbuild-plugin-vue3": "0.5.1",
    "highlight.js": "11.11.1"
  },
  "devDependencies": {
    "@fkui/tsconfig": "6.52.0",
    "@forsakringskassan/commitlint-config": "4.2.2",
    "@forsakringskassan/eslint-config": "15.4.1",
    "@forsakringskassan/eslint-config-cli": "15.4.0",
    "@forsakringskassan/eslint-config-jest": "15.4.0",
    "@forsakringskassan/eslint-config-typescript": "15.4.0",
    "@forsakringskassan/eslint-config-typescript-typeinfo": "15.4.0",
    "@forsakringskassan/eslint-config-vue": "15.4.4",
    "@forsakringskassan/jest-config": "30.4.0",
    "@forsakringskassan/prettier-config": "3.7.7",
    "@html-validate/release-scripts": "7.3.6",
    "@jest/globals": "30.4.1",
    "@tsconfig/node22": "22.0.5",
    "@tsconfig/recommended": "1.0.13",
    "@tsconfig/strictest": "2.0.8",
    "@types/jest": "30.0.0",
    "@types/node": "22.20.1",
    "cypress": "15.18.1",
    "esbuild": "0.28.1",
    "html-validate": "11.5.6",
    "html-validate-vue": "9.3.1",
    "npm-pkg-lint": "5.2.0",
    "npm-run-all2": "9.0.2",
    "rimraf": "6.1.3",
    "sass": "1.101.0",
    "typescript": "6.0.3",
    "vue": "3.5.40",
    "vue-tsc": "3.3.7"
  },
  "peerDependencies": {
    "html-validate": ">= 7.9.0",
    "prettier": "^3.0.0",
    "vue": "^3.4.15"
  },
  "peerDependenciesMeta": {
    "html-validate": {
      "optional": true
    }
  },
  "engines": {
    "node": "^22.16 || >= 24"
  },
  "allowScripts": {
    "@parcel/watcher": false,
    "cypress": true,
    "esbuild": true,
    "fsevents": false,
    "unrs-resolver": false
  }
}
