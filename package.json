{
  "name": "@forsakringskassan/docs-live-example",
  "version": "2.4.2",
  "description": "Components used for live examples",
  "keywords": [
    "documentation"
  ],
  "homepage": "https://github.com/Forsakringskassan/docs-live-example",
  "bugs": "https://github.com/Forsakringskassan/docs-live-example/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/docs-live-example.git"
  },
  "license": "MIT",
  "author": "Försäkringskassan",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "sass": "./dist/main.css",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./htmlvalidate": "./htmlvalidate/index.js",
    "./dist/main.css": "./dist/main.css"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "main.css",
    "htmlvalidate",
    "!**/*.spec.js",
    "!**/*.spec.d.ts"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "rimraf dist",
    "build": "vue-tsc && node build.js",
    "html-validate": "html-validate --ext vue,html src",
    "prepack": "release-prepack --bundle",
    "postpack": "release-postpack package.json",
    "prepublishOnly": "release-prepublish --bundle",
    "pretest": "run-s prettier:check eslint html-validate",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "lint": "run-s prettier:check eslint html-validate",
    "lint:fix": "run-s prettier:write eslint:fix",
    "eslint": "eslint --cache .",
    "eslint:fix": "eslint --fix .",
    "prestart": "npm run build",
    "start": "node ./scripts/serve.mjs"
  },
  "commitlint": {
    "extends": "@forsakringskassan/commitlint-config/no-jira"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-config"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.[jt]s",
      "!**/*.spec.[jt]s",
      "!**/*.d.ts",
      "!**/index.[jt]s",
      "!**/__fixtures__/**"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "preset": "@forsakringskassan/jest-config/esm"
  },
  "dependencies": {
    "esbuild-plugin-vue3": "0.5.1",
    "highlight.js": "11.11.1"
  },
  "devDependencies": {
    "@fkui/tsconfig": "6.43.0",
    "@forsakringskassan/commitlint-config": "3.3.11",
    "@forsakringskassan/eslint-config": "14.1.14",
    "@forsakringskassan/eslint-config-cli": "14.1.11",
    "@forsakringskassan/eslint-config-jest": "14.1.9",
    "@forsakringskassan/eslint-config-typescript": "14.1.15",
    "@forsakringskassan/eslint-config-typescript-typeinfo": "14.1.15",
    "@forsakringskassan/eslint-config-vue": "14.1.15",
    "@forsakringskassan/jest-config": "30.1.3",
    "@forsakringskassan/prettier-config": "3.3.9",
    "@html-validate/release-scripts": "7.1.19",
    "@tsconfig/node20": "20.1.9",
    "@types/jest": "30.0.0",
    "@types/node": "20.19.39",
    "cypress": "15.14.0",
    "esbuild": "0.28.0",
    "html-validate": "10.13.1",
    "html-validate-vue": "8.2.0",
    "npm-pkg-lint": "4.6.5",
    "npm-run-all2": "8.0.4",
    "rimraf": "6.1.3",
    "sass": "1.99.0",
    "typescript": "6.0.3",
    "vue": "3.5.32",
    "vue-tsc": "3.2.7"
  },
  "peerDependencies": {
    "html-validate": ">= 7.9.0",
    "prettier": "^3.0.0",
    "vue": "^3.4.15"
  },
  "peerDependenciesMeta": {
    "html-validate": {
      "optional": true
    }
  },
  "engines": {
    "node": ">= 20"
  }
}
