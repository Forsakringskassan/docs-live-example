{
    "extends": [
        "@tsconfig/recommended",
        "@tsconfig/node22",
        "@tsconfig/strictest"
    ],
    "compilerOptions": {
        /* ts-jest hardcodes deprecated moduleResolution node10 */
        "ignoreDeprecations": "6.0",

        "rootDir": "./src",
        "outDir": "./dist",
        "declarationDir": "./dist",

        "module": "esnext",
        "moduleResolution": "bundler",
        "emitDeclarationOnly": true,
        "sourceMap": true,
        "declaration": true,
        "types": ["jest"],

        /* technical debt */
        "noPropertyAccessFromIndexSignature": false
    },
    "include": ["./src/**/*.ts", "./src/**/*.vue"]
}
